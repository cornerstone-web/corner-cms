# ─── Database ─────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string
# Docker Connection String: "postgresql://postgres:postgres@localhost:5432/postgres"
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ─── Auth0 ────────────────────────────────────────────────────────────────────
# From your Auth0 application (Regular Web App)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret

# A long random secret used to encrypt session cookies (generate with: openssl rand -hex 32)
AUTH0_SECRET=replace_with_64_char_hex_string

# The base URL of your deployed app (no trailing slash)
APP_BASE_URL=https://cms.yoursite.com

# ─── Auth0 Management API (for provisioning new church admins) ─────────────────
# From a separate Machine-to-Machine application in Auth0
# Grant it the "create:users" and "create:user_tickets" Management API permissions
AUTH0_MANAGEMENT_CLIENT_ID=your_mgmt_m2m_client_id
AUTH0_MANAGEMENT_CLIENT_SECRET=your_mgmt_m2m_client_secret

# ─── GitHub App ───────────────────────────────────────────────────────────────
GITHUB_APP_ID=123456
# Multiline PEM — in Vercel, paste the entire key including header/footer lines
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_APP_WEBHOOK_SECRET=your_webhook_secret

# The org-level installation ID for the GitHub App (found in App settings > Installations)
GITHUB_APP_INSTALLATION_ID=12345678

# The GitHub org where church repos live (default: cornerstone-web)
GITHUB_ORG=cornerstone-web

# The template repo to fork when provisioning a new church (default: template-repo)
GITHUB_TEMPLATE_REPO=template-repo

# ─── Token encryption (AES-256) ───────────────────────────────────────────────
# Generate with: openssl rand -hex 32
CRYPTO_KEY=replace_with_64_char_hex_string

# ─── Cloudflare Pages provisioning (optional) ─────────────────────────────────
# If set, pages-cms will automatically create a CF Pages project during provisioning
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_API_TOKEN=your_cloudflare_api_token_with_pages_edit_permission

# ─── R2 Media (corner-media worker) ───────────────────────────────────────────
CORNER_MEDIA_URL=https://your-worker.your-subdomain.workers.dev
CORNER_MEDIA_SECRET=your_hmac_secret_shared_with_corner_media
R2_PUBLIC_URL=https://media.yoursite.com

# ─── Cron ─────────────────────────────────────────────────────────────────────
# Bearer token Vercel sends when calling /api/cron (set in Vercel dashboard too)
CRON_SECRET=replace_with_random_secret

# ─── Cache tuning (optional) ─────────────────────────────────────────────────
# File cache TTL in minutes (default 1440 = 24h). Set to -1 to disable caching.
# FILE_CACHE_TTL=1440
